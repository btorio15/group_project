<section class="map-section">
  <div class="map-header">
    <h2 class="map-title">{{title}}</h2>
    {{#if subtitle}}
      <p class="map-subtitle">{{subtitle}}</p>
    {{/if}}
  </div>

  <div class="map-wrapper">
    <div id="{{mapId}}" class="map-display" role="region" aria-label="Interactive Map">
      {{! Map library (e.g. Leaflet, Mapbox) will mount here }}
    </div>

    {{#if showControls}}
      <div class="map-controls">
        <button class="map-btn map-btn--zoom-in"  aria-label="Zoom in">+</button>
        <button class="map-btn map-btn--zoom-out" aria-label="Zoom out">−</button>
        <button class="map-btn map-btn--reset"    aria-label="Reset view">⟳</button>
      </div>
    {{/if}}
  </div>

  {{#if legend}}
    <div class="map-legend">
      <span class="map-legend__label">{{legend.label}}</span>
      {{#each legend.items}}
        <span class="map-legend__item">
          <span class="map-legend__swatch" style="background:{{this.color}}"></span>
          {{this.label}}
        </span>
      {{/each}}
    </div>
  {{/if}}
</section>