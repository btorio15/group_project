<section class="map-section">
  <div class="map-header">
    <h2 class="map-title">{{title}}</h2>
    {{#if subtitle}}
      <p class="map-subtitle">{{subtitle}}</p>
    {{/if}}
  </div>

  <div class="map-wrapper">
    <div id="{{mapId}}" class="map-display" role="region" aria-label="Interactive Map">
      {{! Map library (e.g. Leaflet, Mapbox) will mount here }}
    </div>

    {{#if showControls}}
      <div class="map-controls">
        <button class="map-btn map-btn--zoom-in"  aria-label="Zoom in">+</button>
        <button class="map-btn map-btn--zoom-out" aria-label="Zoom out">−</button>
        <button class="map-btn map-btn--reset"    aria-label="Reset view">⟳</button>
      </div>
    {{/if}}
  </div>

  {{#if legend}}
    <div class="map-legend">
      <span class="map-legend__label">{{legend.label}}</span>
      {{#each legend.items}}
        <span class="map-legend__item">
          <span class="map-legend__swatch" style="background:{{this.color}}"></span>
          {{this.label}}
        </span>
      {{/each}}
    </div>
  {{/if}}
</section>
<script>
  // Wait until the DOM is fully loaded
  document.addEventListener('DOMContentLoaded', () => {
    // Fetch the API key securely from the server
    fetch('/maps-api-key')
      .then(res => res.json())
      .then(data => {
        const key = data.key;
        const script = document.createElement('script');
        script.src = `https://maps.googleapis.com/maps/api/js?key=${data.key}&callback=initMaps`;
        script.async = true;
        document.head.appendChild(script);
      });

    // Callback to initialize all maps
    window.initMaps = () => {
      document.querySelectorAll('.map-display').forEach(mapDiv => {
        const map = new google.maps.Map(mapDiv, {
          center: { lat: 40.014, lng: -105.2705 }, // Example coords
          zoom: 12
        });

        // Optional: add a marker
        new google.maps.Marker({
          position: { lat: 40.014, lng: -105.2705 },
          map: map,
          title: 'Hello Boulder!'
        });

        // Optional: wire your custom controls
        const wrapper = mapDiv.closest('.map-wrapper');
        if (wrapper) {
          const zoomIn = wrapper.querySelector('.map-btn--zoom-in');
          const zoomOut = wrapper.querySelector('.map-btn--zoom-out');
          const reset  = wrapper.querySelector('.map-btn--reset');

          zoomIn?.addEventListener('click', () => map.setZoom(map.getZoom() + 1));
          zoomOut?.addEventListener('click', () => map.setZoom(map.getZoom() - 1));
          reset?.addEventListener('click', () => map.setCenter({ lat: 40.014, lng: -105.2705 }));
        }
      });
    };
  });
</script>