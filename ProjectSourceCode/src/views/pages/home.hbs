<div class="hero-band">
  <div>
    <div class="hero-eyebrow">Boulder, Colorado · Public Amenity Directory</div>
    <h1 class="hero-h1">Find Amenities<br/>Near You</h1>
    <p class="hero-sub">Community-verified restrooms, wifi, showers, parking, and more across Boulder.</p>
  </div>
  <div>
    <div class="search-form">
      <input type="text" placeholder="Search locations or amenities…"/>
      <button>Search</button>
    </div>
  </div>
</div>

<div class="locations-grid">
  

    {{> map-container
    mapId="main-map"
    showControls=true
  }}
  <div class="categories-section">
    <div class="toolbar">
      <span class="toolbar-title">Browse by Amenity</span>
    </div>
    <div class="categories-grid">
      {{#each amenityCategories}}
        <div class="category-card" data-amenity="{{name}}" role="button" tabindex="0">
          <div class="category-card__icon">
            {{#if (eq name "Wifi")}}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12.55a11 11 0 0 1 14.08 0"/>
                <path d="M1.42 9a16 16 0 0 1 21.16 0"/>
                <path d="M8.53 16.11a6 6 0 0 1 6.95 0"/>
                <line x1="12" y1="20" x2="12.01" y2="20"/>
              </svg>
            {{/if}}
            {{#if (eq name "Restrooms")}}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M7 21v-2a4 4 0 0 1 3-3.87"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
            {{/if}}
            {{#if (eq name "Showers")}}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4v16"/>
                <path d="M4 10h12a2 2 0 0 1 2 2v0a2 2 0 0 1-2 2H4"/>
                <circle cx="8" cy="18" r="1"/>
                <circle cx="12" cy="19" r="1"/>
                <circle cx="10" cy="21" r="1"/>
                <circle cx="16" cy="18" r="1"/>
                <circle cx="14" cy="20" r="1"/>
              </svg>
            {{/if}}
            {{#if (eq name "Parking")}}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="3"/>
                <path d="M9 17V7h4a3 3 0 0 1 0 6H9"/>
              </svg>
            {{/if}}
            {{#if (eq name "Study Spots")}}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
              </svg>
            {{/if}}
          </div>
          <div class="category-card__name">{{name}}</div>
          <div class="category-card__count">{{count}} location{{#if (eq count "1")}}{{else}}s{{/if}}</div>
        </div>
      {{/each}}
    </div>
  </div>

  <div class="toolbar">
    <span class="toolbar-title">Locations</span>
    <select class="amenity-select">
      <option>Any rating</option>
      <option>4+ stars</option>
      <option>3+ stars</option>
    </select>
    <select class="amenity-select distance-select">
      <option>Any distance</option>
      <option>Nearest first</option>
      <option>Farthest first</option>
    </select>
    <div class="toolbar-spacer"></div>
    <button class="add-loc-btn" onclick="window.location.href='/edit'">+ Add Location</button>
  </div>

  <div class="locations-grid__cards">
    {{#each locations}}
      {{> locationbox}}
    {{/each}}
  </div>
</div>

<div class="edit-modal-overlay" id="editModalOverlay" role="dialog" aria-modal="true" aria-labelledby="editModalTitle">
  <div class="edit-modal">
    <div class="edit-modal__header">
      <h2 class="edit-modal__title" id="editModalTitle">Edit Location</h2>
      <button class="edit-modal__close" id="editModalClose" aria-label="Close dialog">&times;</button>
    </div>
    <form class="edit-modal__form" id="editLocationForm" action="/edit" method="POST">
      <input type="hidden" name="id" id="editId" />
      <label>Name
        <input type="text" name="name" id="editName" required />
      </label>
      <label>Address
        <input type="text" name="address" id="editAddress" required />
      </label>
      <label>Image URL
        <input type="text" name="image_url" id="editImageUrl" />
      </label>
      <fieldset>
        <legend>Amenities</legend>
        <label><input type="checkbox" name="amenities" value="Wifi" /> Wifi</label>
        <label><input type="checkbox" name="amenities" value="Showers" /> Showers</label>
        <label><input type="checkbox" name="amenities" value="Parking" /> Parking</label>
        <label><input type="checkbox" name="amenities" value="Restrooms" /> Restrooms</label>
        <label><input type="checkbox" name="amenities" value="Study Spots" /> Study Spots</label>
      </fieldset>
      <div class="edit-modal__actions">
        <button type="button" class="edit-modal__cancel" id="editModalCancel">Cancel</button>
        <button type="submit" class="edit-modal__save">Save Changes</button>
      </div>
    </form>
  </div>
</div>