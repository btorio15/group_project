<div class="hero-band">
  <div>
    <div class="hero-eyebrow">Boulder, Colorado · Public Amenity Directory</div>
    <h1 class="hero-h1">Locations<br/>Near You</h1>
    <p class="hero-sub">Community-verified restrooms, wifi, showers, parking, and more across Boulder.</p>
  </div>
  <div>
  <form class="search-form" action="/locations" method="GET">
  <input id="location-search-input" type="text" name="q"
         placeholder="Search locations or amenities…"
         value="{{searchQuery}}"/>
  <button type="submit">Search</button>
</form>
  </div>
</div>

<div class="locations-grid">
  <div class="locations-grid__cards locations-grid__cards--list">
    {{#each locations}}
      {{> locationbox}}
    {{/each}}
  </div>
</div>