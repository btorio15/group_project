# === Remote database (Supabase) ===
# Uncomment and fill in to use the shared Supabase DB.
# When set, the app ignores the POSTGRES_* / DB_* vars below.
# DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-west-1.pooler.supabase.com:5432/postgres"

# === Local Docker database (fallback when DATABASE_URL is not set) ===
POSTGRES_USER="admin"
POSTGRES_PASSWORD="password"
POSTGRES_DB="amenities_dev"

DB_HOST="db"
DB_PORT="5432"
DB_USER="admin"
DB_PASSWORD="password"
DB_NAME="amenities_dev"

# Node vars
SESSION_SECRET=""
API_KEY=""
